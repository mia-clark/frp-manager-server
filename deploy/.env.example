# Copy to .env and fill in real values. Never commit .env.

# Required: bearer token clients must send as `Authorization: Bearer <token>`.
# Generate one with:  openssl rand -hex 32
FRPMGR_API_TOKEN=change-me-to-a-long-random-string

# Optional overrides:
# FRPMGR_HTTP_PORT=8080
# FRPMGR_CORS_ORIGINS=http://localhost:5173,http://localhost:3000
# FRPMGR_LOG_LEVEL=info
# FRPMGR_DOCS_ENABLED=true   # set to false to hide /api/docs in production

# Build metadata stamped into binaries.
VERSION=dev
# BUILD_DATE is set automatically by `make docker` (date -u +%Y-%m-%d).
